# ================================
# AR.IO BUNDLER CONFIGURATION
# ================================
# Single centralized configuration file for both Payment and Upload services
# Copy this file to .env and configure with your actual values

# ================================
# CORE CONFIGURATION
# ================================
NODE_ENV=production
MIGRATE_ON_STARTUP=false

# ================================
# SERVICE PORTS
# ================================
PAYMENT_SERVICE_PORT=4001
UPLOAD_SERVICE_PORT=3001

# ================================
# INFRASTRUCTURE NETWORK BINDING (docker-compose host ports)
# ================================
# Host interface the Docker infra (Postgres, Redis x2, MinIO console) binds to.
# Default 127.0.0.1 keeps infra off any public/LAN interface; PM2 services
# reach it via localhost. Dev boxes that expose infra over the LAN can set
# this to 0.0.0.0, but NEVER do that on a public-facing production host.
INFRA_BIND_IP=127.0.0.1
# Address the API services (upload/payment/admin) bind to. 0.0.0.0 = all interfaces
# (default; correct when nginx runs on a SEPARATE host). Set to 127.0.0.1 when nginx
# is co-located so the APIs stay loopback-only and are never publicly reachable.
BIND_ADDRESS=0.0.0.0
# Host interface the MinIO S3 API (:9000) binds to. Remote AR.IO gateways pull
# data items from here, so on Hetzner set this to the bundler's PRIVATE vSwitch
# IP (e.g. 10.0.0.X) so the gateways can reach it over the private network.
# Leave at 127.0.0.1 for same-host gateways (they use the docker network alias).
# ⚠️ If you set this to a NON-loopback IP, S3_ENDPOINT (below) MUST use that SAME IP:
# the publish moves off localhost, so the bundler (a host process that reaches MinIO
# via S3_ENDPOINT) can no longer talk to localhost:9000 — uploads fail at storage.
MINIO_S3_BIND_IP=127.0.0.1
# MinIO data directory. Unset = a docker named volume (dev default; lands on the OS
# disk). On a prod box with bulk storage, set a bind-mount path on a dedicated disk
# (e.g. /mnt/minio on an HDD) so object data doesn't fill the OS disk.
MINIO_DATA_PATH=

# ================================
# DATABASE CONFIGURATION
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=turbo_admin
DB_PASSWORD=postgres
DB_WRITER_ENDPOINT=localhost
DB_READER_ENDPOINT=localhost

# Database names (MUST be different for each service)
PAYMENT_DB_DATABASE=payment_service
UPLOAD_DB_DATABASE=upload_service

# Database connection pool configuration (for scale)
# Connection-cap rule: Postgres max_connections (docker-compose.yml) must be
# >= (max processes with a DB pool × DB_POOL_MAX) + overhead. Lower DB_POOL_MAX
# or raise max_connections together; re-check whenever API_INSTANCES changes.
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_ACQUIRE_TIMEOUT=10000
DB_IDLE_TIMEOUT=30000
DB_REAP_INTERVAL=1000

# Per-session safety timeouts applied to every APP connection (not migrations).
# A runaway query or a leaked open transaction can otherwise pin a pooled
# connection — and any row locks it holds — indefinitely. Values in ms; set 0 to
# disable. Keep these comfortably above the largest legitimate app statement
# (e.g. the verify-bundle whole-bundle batch insert).
DB_STATEMENT_TIMEOUT_MS=60000
DB_IDLE_IN_TX_TIMEOUT_MS=60000

# Postgres server tuning (consumed by docker-compose.yml). Defaults match the dev
# box; on a big-RAM prod node set PG_SHARED_BUFFERS≈25% of RAM (e.g. 32GB on 128GB)
# and PG_EFFECTIVE_CACHE_SIZE≈50-75% of RAM (planner hint only; safe to raise).
# Keep PG_MAX_CONNECTIONS >= (procs × DB_POOL_MAX) + overhead.
# NOTE: changing PG_* (esp. enabling pg_stat_statements via shared_preload_libraries)
# requires a full postgres CONTAINER RESTART, not just a reload.
PG_MAX_CONNECTIONS=500
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
# Slow-query log threshold in ms (-1 disables). pg_stat_statements is always on.
PG_LOG_MIN_DURATION_MS=1000

# ================================
# SERVER TIMEOUT CONFIGURATION
# ================================
# Upload Service (supports large files up to 10 GiB).
# REQUEST_TIMEOUT_MS is the TOTAL request time (headers + body) and must be
# large to allow slow big-body uploads. HEADERS_TIMEOUT_MS must stay SHORT
# regardless of body size — a long header timeout is a slowloris DoS vector
# (headers are tiny and arrive in well under a second).
REQUEST_TIMEOUT_MS=600000
KEEPALIVE_TIMEOUT_MS=620000
HEADERS_TIMEOUT_MS=60000

# Graceful-shutdown drain window (ms) for the HTTP APIs. On SIGTERM/SIGINT (e.g.
# `pm2 reload` rolling restart) the API stops accepting new connections and lets
# in-flight requests finish, up to this long, before exiting — so a rolling
# deploy drops zero requests. Keep it < the API's pm2 kill_timeout (5000ms) so
# pm2 never SIGKILLs mid-drain. Default 4000.
SHUTDOWN_DRAIN_MS=4000

# Diagnostic-only: log a WARN if a data-item upload stream goes idle for this many
# ms mid-transfer (a slow/distant client stalling). It does NOT abort the upload —
# it's just an observability breadcrumb — so it's safe to tune or silence. Set 0 to
# disable. Default 3000. (Was a hardcoded 3s ERROR log that made benign client-side
# stalls look like server faults.)
DATA_ITEM_CHUNK_STALL_LOG_MS=3000

# Payment Service (fast requests). Separate PAYMENT_-prefixed vars so the
# payment service NEVER inherits the upload-sized values above from this shared
# file. All stay short.
PAYMENT_REQUEST_TIMEOUT_MS=120000
PAYMENT_KEEPALIVE_TIMEOUT_MS=65000
PAYMENT_HEADERS_TIMEOUT_MS=60000

# Payment Service request-body size limits. koa-bodyparser buffers the body in
# memory BEFORE auth, so these cap pre-auth memory use on public POST endpoints.
# Keep small — payment payloads are tiny (tx ids, x402 metadata); the only larger
# legitimate body is a Stripe webhook event (a few hundred KB).
PAYMENT_JSON_BODY_LIMIT=1mb
PAYMENT_FORM_BODY_LIMIT=256kb
PAYMENT_TEXT_BODY_LIMIT=64kb

# ================================
# SCALE & PERFORMANCE CONFIGURATION
# ================================
# Maximum data item size to cache in Redis (bytes)
# Items larger than this will be stored in object store only
# Default: 100 MB (104857600 bytes)
# WARNING: Setting too high can cause Redis OOM
MAX_CACHE_DATA_ITEM_SIZE=104857600

# Worker concurrency configuration (for BullMQ workers)
# Higher values increase throughput but use more memory
# PLAN_WORKER_CONCURRENCY defaults to 1: the plan handler is a self-draining loop
# triggered on a wall-clock schedule, so 1 is the overlap guard (raising it lets a
# new scheduled plan run start before the previous one finishes).
PLAN_WORKER_CONCURRENCY=1
PREPARE_WORKER_CONCURRENCY=3
POST_WORKER_CONCURRENCY=2
VERIFY_WORKER_CONCURRENCY=3

# In-process job schedulers (replace the old cron-trigger-*.sh crons). Registered
# at startup by the upload-workers process. Cron syntax; set to "" to disable.
PLAN_SCHEDULE_CRON="*/5 * * * *"
CLEANUP_SCHEDULE_CRON="0 2 * * *"

# Pre-creates upcoming permanent_data_items half-month partitions so live rows
# never fall into the DEFAULT partition (an ever-growing DEFAULT defeats
# partitioning and is painful to carve out later). Idempotent; daily is plenty.
ENSURE_PARTITIONS_SCHEDULE_CRON="0 3 * * *"   # set "" to disable
# How many months of partitions to keep pre-created ahead of now.
PARTITION_MONTHS_AHEAD=12

# Re-driver for bundles stranded in posted_bundle (tx header on chain but seeding
# failed and exhausted its BullMQ attempts — otherwise they'd never recover). The
# scheduler re-enqueues seeding for stale posted_bundle rows; after MAX_SEED_REDRIVES
# it demotes the bundle to failed_bundle (items repacked to new_data_item) and
# alerts (posted_bundle_redrive_total / posted_bundle_failed_to_seed_total metrics).
POSTED_REDRIVE_SCHEDULE_CRON="*/10 * * * *"   # set "" to disable
# How long a posted_bundle must sit before it's considered stale (ms). Keep well
# past the seed job's own retry/backoff so mid-retry bundles aren't re-driven early.
POSTED_STALE_THRESHOLD_MS=1800000             # 30 min
MAX_SEED_REDRIVES=5                            # demote to failed_bundle after this many

# ================================
# SECURITY & AUTHENTICATION
# ================================
# Inter-service authentication (MUST match between services)
# Generate with: openssl rand -hex 32
PRIVATE_ROUTE_SECRET=

# JWT secret for token generation
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ================================
# ARWEAVE WALLET CONFIGURATION
# ================================
# Bundle signing wallet (MUST be absolute path)
TURBO_JWK_FILE=/home/vilenarios/ar-io-bundler/wallet.json

# Raw data item signing wallet (for server-signed uploads)
# Can be same as TURBO_JWK_FILE for testing, separate for production
RAW_DATA_ITEM_JWK_FILE=/home/vilenarios/ar-io-bundler/wallet.json

# Wallet addresses (MUST match your wallet.json)
ARWEAVE_ADDRESS=
ARIO_ADDRESS=

# Optional: Additional blockchain addresses for payment service
ETHEREUM_ADDRESS=
SOLANA_ADDRESS=
MATIC_ADDRESS=
BASE_ETH_ADDRESS=
KYVE_ADDRESS=

# ================================
# X402 PAYMENT PROTOCOL (Primary Payment Method)
# ================================
# Enable/disable x402 payments (default: true)
X402_ENABLED=true

# Your receiving wallet address (REQUIRED if x402 enabled)
X402_PAYMENT_ADDRESS=

# ---- Coinbase CDP Credentials (REQUIRED for MAINNET) ----
# Get credentials from: https://portal.cdp.coinbase.com/
# NOT required for testnet (use public facilitator)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ---- Browser Paywall Integration (OPTIONAL) ----
# CDP Client Key enables browser-based payment UI with Coinbase Onramp
# This is the PUBLIC client key (safe for browser/client-side use)
# Leave empty for API-only usage
X_402_CDP_CLIENT_KEY=

# Trusted parent (opener) origins the browser paywall may send the signed payment
# authorization to via postMessage (comma-separated, e.g.
# "https://app.ar.io,https://turbo.ardrive.io"). SECURITY: the paywall NEVER uses
# a wildcard targetOrigin. Leave empty to disable opener postMessage entirely (the
# paywall then shows the X-PAYMENT header for the user to copy) — set this only to
# the exact origin(s) you control that open the paywall popup.
X402_PAYWALL_ALLOWED_ORIGINS=

# ---- Network Configuration ----
# Base Mainnet (Primary - USDC on Base)
X402_BASE_ENABLED=true
BASE_MAINNET_RPC_URL=https://mainnet.base.org
X402_BASE_MIN_CONFIRMATIONS=1
# x402 facilitator URLs. CANONICAL name is the PLURAL, comma-separated
# X402_FACILITATOR_URLS_* (payment-service uses the full list for fallback;
# upload-service uses the first entry). The upload service also still accepts the
# historical SINGULAR X402_FACILITATOR_URL_* as an alias (singular wins if both
# are set) — prefer the plural going forward so one value configures both services.
# Multiple facilitators (comma-separated) for automatic fallback.
# If not set, defaults to: Coinbase, Mogami
# Example: X402_FACILITATOR_URLS_BASE=https://api.cdp.coinbase.com/platform/v2/x402,https://facilitator.mogami.tech
X402_FACILITATOR_URLS_BASE=

# Ethereum Mainnet (Optional)
X402_ETH_ENABLED=false
ETHEREUM_MAINNET_RPC_URL=https://cloudflare-eth.com/
X402_ETH_MIN_CONFIRMATIONS=3
X402_FACILITATOR_URLS_ETH=

# Polygon Mainnet (Optional)
X402_POLYGON_ENABLED=false
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com/
X402_POLYGON_MIN_CONFIRMATIONS=10
X402_FACILITATOR_URLS_POLYGON=

# Base Sepolia Testnet (For Development)
X402_BASE_TESTNET_ENABLED=false
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
X402_FACILITATOR_URLS_BASE_TESTNET=

# ---- Payment Configuration ----
# Payment mode: payg, topup, or hybrid (default)
X402_DEFAULT_MODE=hybrid

# Payment timeout (5 minutes default)
X402_PAYMENT_TIMEOUT_MS=300000

# Price buffer for volatility (15% default)
X402_PRICING_BUFFER_PERCENT=15

# Fraud detection tolerance (5% default)
X402_FRAUD_TOLERANCE_PERCENT=5

# Minimum payment amount in whole USDC dollars (e.g., 0.001 = $0.001)
X402_MINIMUM_PAYMENT_USDC=0.001

# ---- Upload Service x402 Configuration ----
# Fee percentage added to x402 pricing (default: 15%)
# This is your profit margin on top of base Arweave storage cost
X402_FEE_PERCENT=15

# Public URL of upload service (used in x402 payment requirements)
UPLOAD_SERVICE_PUBLIC_URL=http://localhost:3001

# Optional: when this box serves more than one public hostname, list the
# accepted hostnames (comma-separated). An x402 quote then advertises a `resource`
# URL built from the request's own Host when it is in this allowlist (always over
# HTTPS); any other/spoofed Host falls back to UPLOAD_SERVICE_PUBLIC_URL. Unset =
# always use UPLOAD_SERVICE_PUBLIC_URL (unchanged single-host behavior). The
# payment recipient is bound to X402_PAYMENT_ADDRESS, never the host.
# UPLOAD_SERVICE_PUBLIC_HOSTS=upload.ardrive.io,upload.services.ar.io

# ---- CoinGecko API (for AR/USD pricing) ----
# Optional - uses free tier if not set
COINGECKO_API_KEY=
COINGECKO_API_URL=https://api.coingecko.com/api/v3/
# Max age (ms) a cached AR/USD price may be reused when CoinGecko is failing,
# before the x402 oracle fails CLOSED instead of pricing payments off a wildly
# stale price. Rides out a short outage; default 1h.
MAX_STALE_AR_PRICE_MS=3600000

# ================================
# REDIS CONFIGURATION
# ================================
# Redis Cache (ElastiCache - for data caching)
REDIS_CACHE_HOST=localhost
REDIS_CACHE_PORT=6379
ELASTICACHE_HOST=localhost
ELASTICACHE_PORT=6379
ELASTICACHE_NO_CLUSTERING=true
ELASTICACHE_PASSWORD=
ELASTICACHE_USE_TLS=false

# Redis Queues (BullMQ - for job processing)
REDIS_QUEUE_HOST=localhost
REDIS_QUEUE_PORT=6381
REDIS_HOST=localhost
REDIS_PORT_QUEUES=6381

# ================================
# MINIO/S3 CONFIGURATION
# ================================
# S3-compatible object storage. The bundler runs on the HOST and reaches MinIO via
# this endpoint. ⚠️ It must match MINIO_S3_BIND_IP: if you bind MinIO to a vSwitch IP
# for gateway reads, set this to http://<that-same-ip>:9000 — localhost:9000 is no
# longer bound and every upload would fail at the storage step.
S3_ENDPOINT=http://localhost:9000
# PROD: rotate these away from the minioadmin defaults below. These are the
# ROOT/admin MinIO credentials — keep them ONLY on the bundler, never hand them
# to the gateway or any read client.
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_SESSION_TOKEN=

# Dedicated READ-ONLY MinIO user for the AR.IO Gateway (created by minio-init).
# The gateway only needs to read raw data items — give it THESE, not the root
# creds above, so a leaked/over-permissioned gateway can't overwrite or delete
# uploads. PROD: change the secret (the gateway's AWS_SECRET_ACCESS_KEY must match).
GATEWAY_S3_ACCESS_KEY_ID=gateway-readonly
GATEWAY_S3_SECRET_ACCESS_KEY=readonly-change-me

# Bucket names
DATA_ITEM_BUCKET=raw-data-items
BACKUP_DATA_ITEM_BUCKET=backup-data-items

# ---- Durable-store sampling (legacy fs_backup vs object_store) ----
# Each accepted data item is written to durable storage; a signed receipt is only
# returned once a DURABLE store (object_store/MinIO, or the legacy fs_backup) has
# the bytes (cache/Redis does NOT count). These rates control which durable stores
# get a copy (1.0 = every item, 0 = off).
#
# fs_backup is an AWS-Turbo VESTIGE: when object_store was S3, small items were
# kept on local disk to AVOID a paid/slow S3 PUT (S3 was "backup of last resort").
# With object_store = local MinIO, fs_backup is a redundant 3rd copy on the same
# NVMe SSD as the MinIO hot tier — pointless, and its tight 3s write timeout flaps
# a circuit breaker + spams the logs on slow/aborted client uploads. Set to 0 to
# disable; MinIO remains the durable store (keep OBJ_STORE_* at 1.0).
# ⚠️ Never run fs_backup>0 WITH OBJ_STORE_DATA_ITEM_SAMPLING_RATE<1.0: that lets a
# small item be durable ONLY on local disk (not MinIO), which the bundle pipeline
# reads from — a data-availability risk. Keep object_store at 1.0.
FS_BACKUP_WRITE_DATA_ITEM_SAMPLING_RATE=0
FS_BACKUP_WRITE_NESTED_DATA_ITEM_SAMPLING_RATE=0
OBJ_STORE_DATA_ITEM_SAMPLING_RATE=1.0
OBJ_STORE_NESTED_DATA_ITEM_SAMPLING_RATE=1.0

# Optional: Regional configuration
DATA_ITEM_BUCKET_REGION=us-east-1
BACKUP_BUCKET_REGION=us-east-1

# Optional: Retry configuration
S3_RETRY_MAX_ATTEMPTS=5
S3_RETRY_BASE_DELAY_MS=100

# Optional: S3 key prefixes
DATA_ITEM_S3_PREFIX=raw-data-item
MULTIPART_S3_PREFIX=multipart-uploads
BUNDLE_PAYLOAD_S3_PREFIX=bundle-payload
BUNDLE_TX_S3_PREFIX=bundle

# ================================
# TWO-TIER MINIO (bundler hot + archive cold) — OPTIONAL, default OFF
# ================================
# Leave ARCHIVE_DATA_ITEM_BUCKET UNSET to keep single-MinIO behavior (everything
# below is ignored). Set it to turn on the second, archive MinIO that mirrors
# served content (raw data items + bundle payloads) and takes all gateway reads,
# so gateway read traffic never competes with the bundling pipeline on the SSD.
# Stand it up with: docker compose -f docker-compose.yml -f docker-compose.archive.yml up -d
# See docs/architecture/TWO_TIER_MINIO.md.
#
# Archive bucket name — MUST be DISTINCT from DATA_ITEM_BUCKET /
# BACKUP_DATA_ITEM_BUCKET (object-store routing is keyed by bucket name, so a
# shared name would route bundler traffic to the archive endpoint; the bundler refuses to
# wire the archive in that case). The archive lives on a separate endpoint, so a
# distinct name is purely a routing requirement; the gateway just needs to know it.
# ARCHIVE_DATA_ITEM_BUCKET=archive-data-items
# ARCHIVE_S3_ENDPOINT=http://localhost:9002
# ARCHIVE_S3_ACCESS_KEY_ID=minioadmin
# ARCHIVE_S3_SECRET_ACCESS_KEY=minioadmin123
# ARCHIVE_S3_FORCE_PATH_STYLE=true
# Region LABEL for the archive client — MUST be distinct from S3_REGION /
# DATA_ITEM_BUCKET_REGION or the archive client would clobber the bundler client.
# ARCHIVE_BUCKET_REGION=archive
# Archive-copy worker concurrency (bundler→archive mirror job).
# ARCHIVE_COPY_WORKER_CONCURRENCY=3
# Archive retention (days) for the MinIO ILM expiry rule installed by minio-init-archive.
# ARCHIVE_RETENTION_DAYS=90
# Extra days to hold bundler copies after a bundle is permanent before reclaiming
# them (0 = reclaim as soon as the archive copy is confirmed).
# BUNDLER_CLEANUP_GRACE_DAYS=0
# Bind-mount the 16 TiB HDD here (used by docker-compose.archive.yml).
# ARCHIVE_MINIO_DATA_PATH=/mnt/hdd/minio

# ================================
# DATA CLEANUP / TIERED RETENTION
# ================================
# Controls the cleanup-fs job (enqueued by cron-trigger-cleanup.sh). Data is
# stored hot on the filesystem and cold in MinIO/S3; once on Arweave it is
# permanent, so local copies can be aged out:
#   0 to FILESYSTEM_CLEANUP_DAYS : kept on filesystem + MinIO
#   FILESYSTEM_CLEANUP_DAYS to MINIO_CLEANUP_DAYS : MinIO only (FS deleted)
#   beyond MINIO_CLEANUP_DAYS : deleted from MinIO (Arweave is permanent)
# Days after which filesystem-cached data items are deleted.
FILESYSTEM_CLEANUP_DAYS=7
# Days after which MinIO/S3-stored data items are deleted. NOTE: when the
# two-tier archive is enabled (ARCHIVE_DATA_ITEM_BUCKET set), the bundler MinIO is
# reclaimed post-permanence instead (gated on the archive copy + BUNDLER_CLEANUP_GRACE_DAYS),
# and archive retention is governed by ARCHIVE_RETENTION_DAYS, so this value is unused.
MINIO_CLEANUP_DAYS=90

# ================================
# BACKUP (scripts/backup.sh)
# ================================
# Until a data item is verified permanent on Arweave, MinIO is its only copy,
# so back up regularly and OFF-BOX. Suggested crontab (daily 03:00, after the
# 02:00 cleanup), using an absolute NODE-independent shell:
#   0 3 * * * /opt/ar-io-bundler/scripts/backup.sh >> /var/log/bundler/backup.log 2>&1
# Leave unset to default to <repo>/backups. If you set it, use an ABSOLUTE path
# (a relative path resolves unpredictably under cron):
#   BACKUP_DIR=/opt/ar-io-bundler/backups
BACKUP_RETENTION_DAYS=14
# Off-box rsync target (STRONGLY recommended). Empty = local-only backups.
BACKUP_REMOTE=

# ================================
# ARWEAVE GATEWAY CONFIGURATION
# ================================
# Gateway for reads, verification, and GraphQL queries
# Use http://localhost:3000 for local AR.IO Gateway
ARWEAVE_GATEWAY=http://localhost:3000

# Optional: comma-separated list of gateways for read/verify FAILOVER. When set,
# reads (status, price, block height, anchor, balance) and the bundle-tx POST try
# each in order until one succeeds. Unset -> uses ARWEAVE_GATEWAY alone (default,
# no behavior change). Use GENUINELY INDEPENDENT gateways for the redundancy to
# mean anything (e.g. your gateway + arweave.net + a third party).
# ARWEAVE_GATEWAYS=http://localhost:3000,https://arweave.net
# Per-gateway read timeout before failing over (ms, default 15000)
# GATEWAY_READ_TIMEOUT_MS=15000

# Multi-source permanence (OPT-IN, default 1 = legacy single-source). Set to 2
# to require N independent sources (gateways agreeing on >=18 confs, or a 2nd
# gateway's GQL index) before a bundle is irreversibly marked permanent and its
# off-chain copies become eligible for cleanup. Only meaningful with >=2
# INDEPENDENT gateways in ARWEAVE_GATEWAYS. Trade-off: if a configured gateway is
# down for a long time, bundles can't reach quorum -> they stay seeded and their
# local copies linger (storage grows; self-heals on recovery, no data loss).
# PERMANENCE_CONFIRMATION_SOURCES=1
# Gate tiered cleanup on permanent_bundle membership (default true) so an item's
# only off-chain copy is never deleted before the bundle reaches permanence.
# CLEANUP_REQUIRE_PERMANENT_BUNDLE=true

# Public access gateway (can be same as ARWEAVE_GATEWAY)
PUBLIC_ACCESS_GATEWAY=http://localhost:3000

# Upload node for TX headers and chunk uploads
# Should be arweave.net for reliability (AR.IO Gateways don't support /chunk)
ARWEAVE_UPLOAD_NODE=https://arweave.net:443

# Dedicated AR.IO chunk-distributor nodes (comma-separated). Seeding stages each
# bundle chunk and the `broadcast-chunks` worker POSTs each to ONE of these
# (shuffled, with per-node retry + failover); each node does its own multi-tip
# broadcast, so reaching one healthy node lands the chunk. Use PRIVATE IPs — chunk
# POSTs are plaintext. AR.IO node `/chunk` is served on the gateway/envoy port
# (:3000). UNSET → falls back to the single ARWEAVE_UPLOAD_NODE above.
# Example: AR_IO_NODE_URLS=http://10.83.0.7:3000,http://10.83.0.13:3000,http://10.83.0.14:3000
AR_IO_NODE_URLS=
# broadcast-chunks worker concurrency + per-node POST retry/timeout knobs.
BROADCAST_CHUNKS_WORKER_CONCURRENCY=10
CHUNK_POST_MAX_TRIES=3
CHUNK_POST_RETRY_DELAY_MS=2000
CHUNK_POST_TIMEOUT_MS=60000

# Optional: Network request timeout (milliseconds)
ARWEAVE_NETWORK_REQUEST_TIMEOUT_MS=60000

# ================================
# PRICING & ORACLE (backport: Lane 3 / PE-8870, PE-4219/9002)
# ================================
# Base URL for the bytes->winston price oracle; byte count is appended as /<bytes>.
# Unset = legacy https://arweave.net/price (backward compatible).
# Point at your self-hosted gateway for vertical integration, e.g. https://turbo-gateway.com/price
PRICE_ORACLE_GATEWAY_URL=

# Flat per-data-item surcharge in USD, added on top of the byte price across
# price/reserve/check (~$0.02 per 1,000 items). Default: 0.00002
USD_PRICE_PER_DATA_ITEM=0.00002

# ================================
# SOLANA-ARIO / ArNS (backport: Lane 4 / PE-9070) — @ar.io/sdk v4
# ================================
# ARIO gateway Solana RPC endpoint. Unset = SDK network default
# (devnet in dev/test, mainnet otherwise).
ARIO_GATEWAY_URL=

# ARIO payment RECIPIENT (Solana). Falls back to SOLANA_ADDRESS if unset.
# FAIL-CLOSED: the service throws at boot if neither ARIO_ADDRESS nor SOLANA_ADDRESS
# is set — by design, so ARIO payments can never silently credit a wrong wallet.
# (ARIO_ADDRESS is defined in the wallet-addresses section above.)

# ARIO SPL mint address. Unset = DEVNET/MAINNET ARIO mint from the SDK.
ARIO_MINT_ADDRESS=

# bs58-encoded Solana secret key authorizing ArNS writes (purchases/leases).
# Unset = ArNS is READ-ONLY (price/quote work, writes disabled).
# NOTE: this REPLACES the old Arweave ARIO_SIGNING_JWK for ARIO writes.
ARIO_SOLANA_SIGNER_SECRET_KEY=

# ================================
# AR.IO GATEWAY INTEGRATION (Optimistic Caching)
# ================================
# Enable optimistic caching (optical bridging)
OPTICAL_BRIDGING_ENABLED=true

# AR.IO Gateway admin endpoint
OPTICAL_BRIDGE_URL=http://localhost:4000/ar-io/admin/queue-data-item

# AR.IO Gateway admin key
AR_IO_ADMIN_KEY=

# Optional: Additional optical bridge URLs (comma-separated)
OPTIONAL_OPTICAL_BRIDGE_URLS=

# Optional: GraphQL endpoint(s) the sitrep's index-durability check queries (comma-separated).
# Unset = derived from the optical bridge host(s) as http(s)://<host>/graphql (the indexer).
# Point at the public gateway (e.g. https://turbo-gateway.com/graphql) to verify the client-facing view.
INDEX_VERIFY_GRAPHQL_URLS=

# Optional: tag/owner/target-based optical routing (surface 1 only).
# A JSON array of rules; for each rule, the matching subset of an optical batch is
# ALSO posted to that rule's endpoint (additive alongside OPTICAL_BRIDGE_URL).
# Routes are best-effort and fire-and-forget, exactly like OPTIONAL_OPTICAL_BRIDGE_URLS:
# a route failure is logged + counted but never blocks/fails the optical job (only
# the primary OPTICAL_BRIDGE_URL is must-succeed).
# Unset/blank => no custom routes => behavior unchanged. Invalid JSON disables all
# custom routes (logged); a single invalid rule is skipped and the rest still load.
# A rule whose url equals OPTICAL_BRIDGE_URL is skipped (already covered by primary).
# Metric: optical_custom_route_post_total{rule,result}.
#
# Matchers (all in a rule's `match` array must pass = AND; empty/omitted = match all):
#   {"type":"tag","name":"App-Name","value":"MyApp"}        exact tag value
#   {"type":"tag","name":"App-Name","valuePrefix":"ArDrive"} tag value prefix
#   {"type":"tag","name":"Content-Type"}                     tag present (any value)
#   {"type":"owner","addresses":["<address>", ...]}          by uploader address
#   {"type":"target","addresses":["<address>", ...]}         by data-item target
# owner/target use the data item's NATIVE address form per signature type
# (0x EIP-55-checksummed for Ethereum, base58 for Solana, base64url for Arweave)
# and are matched case-sensitively — use the exact form the gateway reports.
#
# Per-rule "adminKeyName": bearer token from OPTICAL_ADMIN_KEY_<NAME> (legacy
# ARDRIVE_ADMIN_KEY_<NAME> still honored). If set but unresolved, the route is
# sent with no/empty auth (the primary AR_IO_ADMIN_KEY is NOT inherited).
# Avoid '#' anywhere in the value — unquoted .env treats it as a comment.
#
# Example (single line in the actual .env):
# OPTICAL_ROUTING_RULES=[{"name":"perma","url":"https://perma.online/ar-io/admin/queue-data-item","adminKeyName":"PERMA","match":[{"type":"tag","name":"App-Name","valuePrefix":"ArDrive"}]},{"name":"vilenarios","url":"https://vilenarios.com/ar-io/admin/queue-data-item","adminKeyName":"VILENARIOS","match":[{"type":"owner","addresses":["0xAE57B0eC2Ef81142882e27AE3833deE42c31Ad75"]}]}]
# OPTICAL_ADMIN_KEY_PERMA=<perma.online gateway admin key>
# OPTICAL_ADMIN_KEY_VILENARIOS=<vilenarios.com gateway admin key>
OPTICAL_ROUTING_RULES=

# --------------------------------
# Optimistic surfaces (enable-matrix)
# --------------------------------
# Three INDEPENDENT, strictly best-effort pushes that warm the gateway BEFORE a
# bundle mines. None of them ever block or fail the upload or the on-chain post;
# each has its own gate and its own Prometheus metric. (See
# packages/upload-service/CLAUDE.md → "Optimistic surfaces" for the full table.)
#
#   1) Data-item headers  — gate: OPTICAL_BRIDGING_ENABLED (default ON, above)
#                           metric: *_optical_failure_count
#   2) Bundle-tx header    — gate: OPTIMISTIC_TX_BRIDGE_ENABLED (default OFF)
#                           metric: optimistic_tx_post_total{result}
#   3) Bundle chunks       — gate: CHUNK_CACHE_BRIDGE_ENABLED (default OFF)
#                           metric: chunk_cache_bridge_total{result}
#
# All three require AR_IO_ADMIN_KEY (above) where they hit the admin API.
# Seeding to ARWEAVE_UPLOAD_NODE is SEPARATE from these and always runs — the
# chunk-cache surface (3) does NOT change where bytes land on chain.

# Surface 2: optimistically index the bundle TX on the gateway so it resolves
# (GraphQL) before it mines. Opt-in; needs AR_IO_ADMIN_KEY.
OPTIMISTIC_TX_BRIDGE_ENABLED=false
# Optional explicit endpoint for surface 2. When unset it is derived from
# OPTICAL_BRIDGE_URL (…/queue-data-item → …/queue-optimistic-tx). Set this when
# your optical URL doesn't follow that convention so the surface doesn't silently
# disable itself.
OPTIMISTIC_TX_BRIDGE_URL=

# Surface 3: best-effort push of a seeded bundle's chunks to the read gateway's
# /chunk cache (ARWEAVE_GATEWAY), warming it before the TX mines. Default OFF;
# failure NEVER affects seeding to ARWEAVE_UPLOAD_NODE.
CHUNK_CACHE_BRIDGE_ENABLED=false
# Optional: batch size for the per-BDI optical fan-out (addBulk). Default 50.
BDI_OPTICAL_FAN_OUT_BATCH_SIZE=50

# --- Optical-post burst resilience (BDI fan-out) ---
# ArDrive emits one BDI per subfolder; unbundling fans out one optical post per
# nested child, so a burst can flood the gateway's optical endpoint and trip its
# circuit breaker (→ permanent post failures even though the data is bundled
# fine). These knobs keep that burst from breaking optical indexing.
#
# Worker rate limiter: cap optical posts to OPTICAL_POST_RATE_MAX per
# OPTICAL_POST_RATE_DURATION_MS (across the worker) so the gateway is never
# saturated. Set OPTICAL_POST_RATE_MAX=0 to disable (unbounded — legacy behavior).
OPTICAL_POST_RATE_MAX=50
OPTICAL_POST_RATE_DURATION_MS=1000
# Optical worker concurrency (was hardcoded 5).
OPTICAL_WORKER_CONCURRENCY=5
# Circuit-breaker (opossum) for the optical POST. Timeout default raised from the
# old hardcoded 3000ms — a loaded gateway taking 3–5s is working, not broken.
OPTICAL_BREAKER_TIMEOUT_MS=10000
OPTICAL_BREAKER_ERROR_THRESHOLD_PCT=50
OPTICAL_BREAKER_RESET_TIMEOUT_MS=30000
# Optical-post retry policy. More attempts + longer exponential backoff than the
# global default (3 / 5s) so the retry schedule STRADDLES the breaker's open
# window (above) instead of all retries landing inside it. 15s exp → ~15/30/60/120s.
OPTICAL_POST_ATTEMPTS=5
OPTICAL_POST_BACKOFF_MS=15000

# ================================
# ADMIN DASHBOARD (admin-service, port 3002)
# ================================
# The dashboard + Bull Board are protected by a session login at /admin/login.
# Keep port 3002 admin-only (VPN/SSH tunnel) — never expose it publicly.
#
# RECOMMENDED — first-run setup (no secret in this file):
#   Leave ADMIN_PASSWORD/ADMIN_PASSWORD_HASH below UNSET. On first visit the
#   dashboard shows /admin/setup; you pick a username + password in the browser,
#   the server hashes it with Argon2id and stores the HASH ONLY in ADMIN_AUTH_FILE
#   (chmod 600). Setup then closes (it is not a password reset). Nothing is in
#   plaintext and there is no CLI step.
#   SECURITY: until the credential exists the service is in "setup mode". To stop
#   a network client from claiming admin ownership first, first-run setup is
#   LOOPBACK-ONLY by default — complete it from the host (e.g. an SSH tunnel to
#   port 3002). For remote/proxied setup, set ADMIN_SETUP_TOKEN (below) and POST
#   /admin/setup with an `x-admin-setup-token` header carrying that value. When
#   ADMIN_TRUST_PROXY=true, a token is REQUIRED (a proxy makes every client look
#   loopback). Pre-provisioning ADMIN_PASSWORD/ADMIN_PASSWORD_HASH disables setup
#   mode entirely and is the simplest hardened option.
# ADMIN_SETUP_TOKEN=        # shared secret authorizing remote first-run setup
# ADMIN_AUTH_FILE=          # default: <repo>/.admin-auth.json (must persist across deploys)
#
# OPTIONAL env override (takes precedence over the file) — if you would rather
# configure the credential like every other secret here:
ADMIN_USERNAME=admin
#   - Simplest: a plaintext password (consistent with DB_PASSWORD/JWT_SECRET below).
# ADMIN_PASSWORD=
#   - Or hash-at-rest: generate with `yarn workspace @ar-io-bundler/admin-service hash-password`.
ADMIN_PASSWORD_HASH=
# Cookie-signing key. OPTIONAL — if unset, a stable key is derived from
# PRIVATE_ROUTE_SECRET automatically. (Note: the session store is in-memory, so
# admins re-login after a restart regardless of this value.)
# ADMIN_SESSION_SECRET=
# Session lifetime in ms (default 8h) and brute-force lockout tuning.
# ADMIN_SESSION_TTL_MS=28800000
# ADMIN_MAX_FAILED_LOGINS=5
# ADMIN_LOCKOUT_MS=900000
# Cookie Secure flag. Defaults to true (HTTPS-only) — leave it. Set false ONLY
# when reaching the dashboard over plain HTTP (e.g. a dev SSH tunnel).
# ADMIN_COOKIE_SECURE=true
# REQUIRED when behind a reverse proxy (nginx): trust X-Forwarded-For so lockout/
# audit see the real client IP. Off by default so a directly-reachable instance
# can't be IP-spoofed to bypass the lockout.
# ADMIN_TRUST_PROXY=false
# Port override (default 3002)
# BULL_BOARD_PORT=3002
#
# ---- Operations monitoring (pipeline / wallet / storage / trends) ----
# Low-balance warning threshold for the bundle-signing wallet, in AR (the
# dashboard flags the wallet when it drops below this; posting fails at 0).
# ADMIN_WALLET_LOW_AR=0.5
# Filesystem path whose disk usage is reported in System Health. Defaults to
# MINIO_DATA_PATH when set (so the disk that fills with object data is watched),
# else "/".
# ADMIN_DISK_PATH=/
# Disk usage % thresholds for the health rollup (default warn 80 / crit 90).
# ADMIN_DISK_WARN_PCT=80
# ADMIN_DISK_CRIT_PCT=90
# Trend-history sampler cadence in ms (default 120000 = 2 min; 0 disables). The
# admin process records a compact datapoint on this cadence for the 24h sparklines
# using only cheap queries (not the full dashboard compute).
# ADMIN_HISTORY_SAMPLE_MS=120000
# Hard server-side cap (ms) on every admin DB query so a stats query can never run
# away and load the DB (default 15000). Admin reads also prefer DB_READER_ENDPOINT
# (the read replica, set in the DATABASE section) when configured.
# ADMIN_DB_STATEMENT_TIMEOUT_MS=15000

# ================================
# INTER-SERVICE COMMUNICATION
# ================================
# Payment service URL for upload service (NO protocol prefix)
PAYMENT_SERVICE_BASE_URL=localhost:4001

# Optional: Protocol override (defaults to "http")
PAYMENT_SERVICE_PROTOCOL=http

# ================================
# PAYMENT SERVICE CONFIGURATION
# ================================
# ---- Cryptocurrency Payments (Secondary) ----
# Enable crypto payment monitoring
CRYPTO_MONITORING_ENABLED=false

# Gateway URLs for different blockchains
ETHEREUM_GATEWAY=https://cloudflare-eth.com/
MATIC_GATEWAY=https://polygon-rpc.com/
SOLANA_GATEWAY=https://api.mainnet-beta.solana.com/
KYVE_GATEWAY=https://api.kyve.network/
BASE_ETH_GATEWAY=https://mainnet.base.org

# Exclude addresses from crypto fund monitoring (comma-separated)
CRYPTO_FUND_EXCLUDED_ADDRESSES=

# Minimum confirmations for crypto payments
ARWEAVE_MIN_CONFIRMATIONS=18
ETHEREUM_MIN_CONFIRMATIONS=5
MATIC_MIN_CONFIRMATIONS=12
BASE_ETH_MIN_CONFIRMATIONS=5
DEFAULT_MIN_CONFIRMATIONS=5

# Crypto payment polling configuration. These govern the synchronous tx lookup on
# the public POST /account/balance/:token route (and apply to Arweave too — the
# ArweaveGateway no longer hardcodes its own larger values). Backoff is exponential
# (WAIT * 2^attempt) but each delay is capped by MAX_PAYMENT_TX_POLLING_DELAY_MS so a
# missing-tx lookup can't tie up a request for minutes. Keep ATTEMPTS modest since
# this blocks an unauthenticated request.
PAYMENT_TX_POLLING_WAIT_TIME_MS=500
MAX_PAYMENT_TX_POLLING_ATTEMPTS=5
MAX_PAYMENT_TX_POLLING_DELAY_MS=8000

# ---- Stripe Payments (Optional) ----
# Enable Stripe credit card payments
STRIPE_ENABLED=false

# Stripe API credentials
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payment quote expiration (30 minutes default)
TOP_UP_QUOTE_EXPIRATION_MS=1800000

# Auto Stripe tax
ENABLE_AUTO_STRIPE_TAX=false

# ---- ArNS (Arweave Name System) (Optional) ----
# ArNS is enabled by setting the ARIO_* vars above (ARIO_GATEWAY_URL +
# ARIO_SOLANA_SIGNER_SECRET_KEY for writes); there is no separate enable flag.
# (The old ARNS_ENABLED was never read by the code and has been removed.)

# Legacy Arweave ARIO signer — SUPERSEDED by ARIO_SOLANA_SIGNER_SECRET_KEY (above).
# Leave this COMMENTED OUT. Do NOT set it to an empty value: the code does
# JSON.parse(ARIO_SIGNING_JWK) when the var is present, so an empty string would
# crash payment-service at boot. Only set it (to a valid JWK) if you truly need
# the legacy path.
# ARIO_SIGNING_JWK=

# ArNS configuration
ARIO_PROCESS_ID=
CU_URL=
ARIO_LEASE_NAME_DUST_AMOUNT=1
ARIO_PERMA_BUY_NAME_DUST_AMOUNT=5

# ---- Gifting (Optional) ----
# Enable gifting via email
GIFTING_ENABLED=false
GIFTING_EMAIL_ADDRESS=gift@ardrive.io
MAX_GIFT_MESSAGE_LENGTH=250

# ---- Email Notifications (Optional) ----
# Mandrill/SendGrid for email notifications
MANDRILL_API_KEY=
SENDGRID_API_KEY=

# ---- Payment Service Features ----
# Maximum allowed chargebacks before marking wallet as fraudulent
MAX_ALLOWED_CHARGE_BACKS=1

# Tokens exempt from fees (comma-separated)
TOKENS_WITHOUT_FEES=

# Public gateway FQDNs (comma-separated)
PUBLIC_GATEWAY_FQDNS=

# ================================
# UPLOAD SERVICE CONFIGURATION
# ================================
# ---- Upload Features ----
# Allow listed addresses for free uploads (comma-separated)
ALLOW_LISTED_ADDRESSES=

# Skip balance checks (for testing)
SKIP_BALANCE_CHECKS=false

# Data item and bundle size limits
MAX_DATA_ITEM_SIZE=10737418240
MAX_DATA_ITEM_LIMIT=10000
MAX_BUNDLE_SIZE=2147483648
FREE_UPLOAD_LIMIT=517120

# Allow ArFS data
ALLOW_ARFS_DATA=false

# Number of trusted reverse-proxy hops in front of the upload service. Used to
# pick the real client IP from X-Forwarded-For for per-IP free-upload metering
# (the IP appended by the outermost trusted proxy — the Nth value from the right
# — so a client cannot spoof its metered identity by prepending fake hops).
#   1 = standard prod topology (one co-located nginx, $proxy_add_x_forwarded_for)
#   0 = directly exposed, no trusted proxy (X-Forwarded-For ignored; socket only)
#   2+ = additional trusted hops (e.g. a load balancer in front of nginx)
TRUSTED_PROXY_COUNT=1

# ---- Upload Service Features ----
# Bundle metadata tags
APP_NAME=AR.IO Bundler

# Blocklisted addresses (comma-separated)
BLOCKLISTED_ADDRESSES=

# Allow listed signature types (comma-separated signature type IDs)
ALLOW_LISTED_SIGNATURE_TYPES=

# ---- Data Caches & Indexes ----
# Data caches (comma-separated)
DATA_CACHES=

# Fast finality indexes (comma-separated)
FAST_FINALITY_INDEXES=

# ---- Special Address Lists (comma-separated) ----
WARP_ADDRESSES=
REDSTONE_ORACLE_ADDRESSES=
FIRST_BATCH_ADDRESSES=
AO_ADDRESSES=
KYVE_ADDRESSES=
ARIO_MAINNET_PROCESSES=
ARIO_TESTNET_PROCESSES=
ANT_REGISTRY_MAINNET_PROCESSES=
ANT_REGISTRY_TESTNET_PROCESSES=
SKIP_OPTICAL_POST_ADDRESSES=

# ---- Timing Configuration ----
# Overdue data item threshold (milliseconds)
OVERDUE_DATA_ITEM_THRESHOLD_MS=300000

# In-flight data item TTL (seconds)
# Should be longer than max expected upload time
# 10 GiB @ 100 MB/s = ~100 seconds, set to 600s (10 min) for safety
IN_FLIGHT_DATA_ITEM_TTL_SECS=600

# Quarantined small data item TTL (seconds)
QUARANTINED_SMALL_DATAITEM_TTL_SECS=432000

# ---- Filesystem Storage (Optional) ----
# Path for persistent data item backup storage
FS_DATA_PATH=./upload-service-data

# Temporary file storage
TEMP_DIR=./temp

# EFS mount point (if using network filesystem)
EFS_MOUNT_POINT=

# ---- Database Migration Backfill (Advanced) ----
PERMANENT_DATA_ITEM_BACKFILL_START_BLOCK=1045991
PERMANENT_DATA_ITEM_BACKFILL_END_BLOCK=1470456

# ================================
# WORKER CONFIGURATION
# ================================
# Worker concurrency settings
WORKER_CONCURRENCY_ADMIN_CREDIT=2
WORKER_CONCURRENCY_PENDING_TX=1

# PM2 instance configuration
API_INSTANCES=2
WORKER_INSTANCES=1

# ================================
# LOGGING & MONITORING
# ================================
# Logging configuration
LOG_LEVEL=info
LOG_ALL_STACKTRACES=false
LOG_FORMAT=simple
DISABLE_LOGS=false

# ---- OpenTelemetry (Optional) ----
# Enable OpenTelemetry tracing
OTEL_ENABLED=false
OTEL_COLLECTOR_URL=
OTEL_SAMPLE_RATE=200

# ---- Prometheus (Optional) ----
# Prometheus metrics port
PROMETHEUS_PORT=9090

# ---- Per-process Prometheus scrape endpoints (upload-service) ----
# A dedicated HTTP metrics server is started in each upload-api and upload-workers
# process, exposing that process's prom-client registry at /metrics (and
# /bundler_metrics) on `<basePort> + NODE_APP_INSTANCE`. This is what makes the
# BULL-PIPELINE metrics scrapeable: they are incremented in upload-workers (a fork
# process with no Koa route), and upload-api runs in PM2 cluster mode where the
# shared :3001 route flip-flops between instances. The collector scrapes every
# instance port and Prometheus sum()s across them.
#   upload-api instances:  9301, 9302, ... (one per API_INSTANCES)
#   upload-workers:        9311
# Keep UPLOAD_WORKERS_METRICS_PORT > UPLOAD_API_METRICS_PORT + API_INSTANCES so the
# ranges never overlap. Firewall these ports to the collector CIDRs (no auth).
METRICS_SERVER_ENABLED=true
UPLOAD_API_METRICS_PORT=9301
UPLOAD_WORKERS_METRICS_PORT=9311
# METRICS_BIND_ADDRESS=0.0.0.0   # set to a private/tailnet IP to limit exposure

# ================================
# SLACK NOTIFICATIONS & ALERTS (Optional)
# ================================
# One Slack BOT TOKEN drives every notification (ops alerts + payment top-ups),
# routed to different channels by channel ID. Create a Slack app, add the
# `chat:write` bot scope, install it to the workspace, and INVITE the bot to
# each channel below (/invite @YourBot) or posts fail with `not_in_channel`.
#
# Bot User OAuth Token (starts with xoxb-). Shared by payment-service and the
# admin-dashboard health alerter.
SLACK_OAUTH_TOKEN=

# Channel IDs (the C0XXXX id, NOT the #name — copy via channel → View details).
SLACK_ALERT_CHANNEL_ID=             # ops/health alerts (service/infra/queue issues)
SLACK_TURBO_TOP_UP_CHANNEL_ID=      # payment / crypto top-up notifications
SLACK_TURBO_ADMIN_CHANNEL_ID=       # payment-service admin/failure notices (legacy default)
SLACK_TURBO_ARNS_BUYS_CHANNEL_ID=   # ArNS purchase notifications

# On-demand status posts (scripts/ops/slack-post.js) — operator/agent-triggered,
# separate from the automated alerter. Channel falls back to SLACK_ALERT_CHANNEL_ID.
SLACK_STATUS_CHANNEL_ID=            # dedicated status channel (keeps routine posts out of the alarm channel)
SLACK_STATUS_USERNAME=             # sender name (default "Bundler Ops")
SLACK_STATUS_ICON=                 # emoji icon (default ":satellite_antenna:")

# Standardized alert envelope (every Slack message — ops alerts, heartbeat,
# payment notifications — shares one colored, labeled format):
# Deployment label stamped on EVERY message so an admin knows which bundler it's
# from (e.g. "bundler-prod" vs "bundler-dev"). Defaults to NODE_ENV.
ALERT_ENV_LABEL=
# Optional "where to look" link shown in the ops-alert footer (e.g. the public
# admin dashboard URL behind your reverse proxy). Leave empty to omit the link.
ADMIN_DASHBOARD_URL=
# Optional runbook link shown in the ops-alert footer (your hosted ops docs).
ALERT_RUNBOOK_URL=
# Optional Slack mention prepended to CRITICAL alerts ONLY, so they actually
# notify someone (a posted-but-unpinged critical is easy to miss). Examples:
#   <!here>  ·  <!channel>  ·  a user group <!subteam^S0XXXXXXX>  ·  <@U0XXXXXXX>
# Leave empty for no ping. Warnings/info never ping.
ALERT_MENTION=

# ---- Health Alerter (admin-dashboard) ----
# The alerter mirrors the dashboard's health rollup: it alerts on exactly the
# issues the dashboard shows (pipeline/wallet/payments/storage/schedulers/recent
# queue failures), plus raw Postgres/Redis/process liveness. Alert THRESHOLDS are
# therefore the rollup's — tuned via the ADMIN_*/POSTED_* vars the dashboard uses
# (e.g. ADMIN_DISK_WARN_PCT, POSTED_STALE_THRESHOLD_MS), not here.
#
# Master switch. Off by default — set true once channels above are wired.
ALERTS_ENABLED=false
# How often to evaluate health (ms).
ALERT_CHECK_INTERVAL_MS=60000
# Ongoing-issue reminder cadence, tiered by severity. A ✅ resolved message is
# always sent once when an issue clears. Default: re-ping criticals every 30 min,
# warnings only every 4 h (keeps lingering low-severity issues from nagging).
ALERT_REMINDER_MS=1800000
ALERT_WARNING_REMINDER_MS=14400000
# Anti-flap: a liveness issue (Postgres/Redis/process down) must fail this many
# CONSECUTIVE checks before firing, so a single-tick blip from a partial restart
# (e.g. `pm2 restart upload-workers`) never pages. 2 ≈ tolerate ~2 min. Rollup
# issues are already age-based, so they still fire on first detection.
ALERT_FAILURES_BEFORE_FIRING=2
# Boot grace: skip evaluation for this long after the alerter starts, so a full
# stack restart settles before anything is judged (ms).
ALERT_STARTUP_GRACE_MS=120000
# Post a one-line "alerter online" to Slack on every start. Off by default — it's
# noisy on restarts; rely on the daily heartbeat below to know the alerter is up.
ALERT_STARTUP_PING=false
# Daily heartbeat hour (server local 0–23): once/day post an all-clear / digest so
# silence is trustworthy (you know the alerter is alive and where things stand).
# Set to "" to disable.
ALERT_HEARTBEAT_HOUR=9
# Quiet hours (server-local "START-END", e.g. "22-7"): WARNINGS are deferred until
# the window ends (they fire then if still present). CRITICALs and ✅ resolves
# ALWAYS go through. Empty = no quiet hours. (Reminders/resolves thread under the
# original alert; alerter state survives restarts via Redis — no extra config.)
ALERT_QUIET_HOURS=

# ---- Debug Flags ----
# Stream debugging
STREAM_DEBUG=false

# ================================
# RATE LIMITING (Optional)
# ================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ================================
# ADVANCED CONFIGURATION (Rarely Changed)
# ================================
# PostgreSQL version
POSTGRES_VERSION=16.1
