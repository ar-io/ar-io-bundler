# Paths are relative to the build context, which for this Dockerfile is the
# MONOREPO ROOT (docker-compose.yml sets context: ../..). Keep .yarn/ (cache +
# plugins) and every package.json — the root install needs them.
**/node_modules
**/.git
**/lib
**/coverage
**/.nyc_output
**/*.log
**/.husky
**/.vscode
**/.idea
**/Dockerfile*
**/docker-compose*
**/.env
**/.env.*
**/tmp
**/temp
